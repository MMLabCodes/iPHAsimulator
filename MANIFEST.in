# Include documentation and configuration files
include README.md
include LICENSE
include CONTRIBUTING.md
include ARCHITECTURE.md
include requirements.txt

# Include all files in these directories
recursive-include modules *.py
recursive-include examples *.py
recursive-include tutorials *.ipynb
recursive-include docs *.rst *.md *.txt
recursive-include pdb_files *.prepi *.pdb *.csv
recursive-include bin *.sh *.yml

# Exclude unnecessary files
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.pyc
global-exclude .ipynb_checkpoints
global-exclude .pytest_cache
